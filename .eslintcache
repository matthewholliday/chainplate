s during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/Users/matthew/Documents/GitHub/chainplate/src/renderer/src/App.tsx:211:34\n  209 |   const transport = useMemo(\n  210 |     () =>\n> 211 |       new AssistantChatTransport({\n      |                                  ^\n> 212 |         api: `${chatApiUrl}/api/${mode}`,\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 213 |         body: () => {\n      …\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 235 |         }\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 236 |       }),\n      | ^^^^^^^^ Cannot access ref value during render\n  237 |     // pendingRef is stable (useRef); chatApiUrl changes only on server restart\n  238 |     // eslint-disable-next-line react-hooks/exhaustive-deps\n  239 |     [chatApiUrl, mode, workspaceRoot]",{"range":"3655","text":"3036"},{"range":"3656","text":"3036"},{"range":"3657","text":"3036"},{"range":"3658","text":"3032"},"Replace `'\\n\\n---\\n\\n')` with `\"\\n\\n---\\n\\n\");`",{"range":"3659","text":"3660"},"Replace `'##·Retrieved·Context\\n\\n'·+·contextBlock` with `\"##·Retrieved·Context\\n\\n\"·+·contextBlock;`",{"range":"3661","text":"3662"},{"range":"3663","text":"3036"},{"range":"3664","text":"3036"},{"range":"3665","text":"3032"},{"range":"3666","text":"3036"},{"range":"3667","text":"3032"},{"range":"3668","text":"3032"},{"range":"3669","text":"3036"},"Replace `()·=>` with `⏎····()·=>⏎·····`",{"range":"3670","text":"3671"},"Replace `····if·(Array.isArray(m.parts)·&&·m.parts.some((p:·any)·=>·p.type·!==·'step-start'))·return·true` with `········if·(⏎··········Array.isArray(m.parts)·&&⏎··········m.parts.some((p:·any)·=>·p.type·!==·\"step-start\")⏎········)⏎··········return·true;`",{"range":
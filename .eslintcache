 the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/matthew/Documents/GitHub/chainplate/src/renderer/src/components/assistant-ui/attachment.tsx:33:7\n  31 |   useEffect(() => {\n  32 |     if (!file) {\n> 33 |       setSrc(undefined);\n     |       ^^^^^^ Avoid calling setState() directly within an effect\n  34 |       return;\n  35 |     }\n  36 |",{"range":"3994","text":"3547"},{"range":"3995","text":"3543"},"Replace `'@shared/models'` with `\"@shared/models\";`",{"range":"3996","text":"3997"},{"range":"3998","text":"3530"},{"range":"3999","text":"3036"},{"range":"4000","text":"3036"},"Replace `'bg-red-500'` with `\"bg-red-500\";`",{"range":"4001","text":"4002"},"Replace `'bg-orange-400'` with `\"bg-orange-400\";`",{"range":"4003","text":"4004"},"Replace `'bg-amber-400'` with `\"bg-amber-400\";`",{"range":"4005","text":"4006"},"Replace `'bg-[--brand-dim]'` with `\"bg-[--brand-dim]\";`",{"range":"4007","text":"4008"},"Replace `'text-red-500'` with `\"text-red-500\";`",{"range":"4009","text":"4010"},"Replace `'text-orange-400'` with `\"text-orange-400\";`",{"range":"4011","text":"4012"},"Replace `'text-amber-400'` with `\"text-amber-400\";`",{"range":"4013","text":"4014"},"Replace `'text-muted-foreground'` with `\"text-muted-foreground\";`",{"range":"4015","text":"4016"},{"range":"4017","text":"3036"},{"range":"4018","text":"3036"},{"range":"4019","text":"3036"},{"range":"4020","text":"3036"},"Replace `'flex·items-center·gap-1.5'` with `\"flex·items-center·gap-1.5\"`",{"range":"4021","text":"4022"},"Replace `'a
rt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/matthew/Documents/GitHub/chainplate/src/renderer/src/App.tsx:370:7\n  368 |   useEffect(() => {\n  369 |     if (!window.electronAPI?.getChatApiUrl) {\n> 370 |       setError('Preload bridge failed to load. Restart the application.')\n      |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  371 |       return\n  372 |     }\n  373 |","Replace `'Preload·bridge·failed·to·load.·Restart·the·application.')` with `\"Preload·bridge·failed·to·load.·Restart·the·application.\");`",{"range":"3735","text":"3736"},{"range":"3737","text":"3036"},"Replace `err·instanceof·Error·?·err.message·:·'Failed·to·connect·to·chat·server')` with `⏎··········err·instanceof·Error⏎············?·err.message⏎············:·\"Failed·to·connect·to·chat·server\",⏎········);`",{"range":"3738","text":"3739"},{"range":"3740","text":"3036"},{"range":"3741","text":"3036"},{"range":"3742","text":"3036"},{"range":"3743","text":"3036"},{"range":"3744","text":"3036"},{"range":"3745","text":"3036"},{"range":"3746","text":"3036"},{"range":"3747","text":"3036"},{"range":"3748","text":"3036"},{"range":"3749","text":"3036"},{"range":"3750","text":"3036"},{"range":"3751","text":"3032"},{"range":"3752","text":"3036"},{"range":"3753","text":"3036"},{"range":"3754","text":"3036"},{"range":"3755","text":"3036"},{"range":"3756","text":"3036"},{"range":"3757","text":"3036"},{"range":"3758","text":"3036"},{"range":"3759","text":"3036"},{"range":"3760","text":"3036"},{"range":"3761","text":"3036"},{"range":"3762","text":"3036"},{"range":"3763","text":"3036"},{"range":"3764","text":"3036"},{"range":"3765","text":"3036"},{"range":"3766","text":"3036"},{"range":"3767","text":"3036"},{"range":"3768","text":"3036"},{"range":"3769","text":"3036"},{"range":"3770","text":"3036"},{"range":"3771","text":"3036"},{"range":"3772","text":"3036"},{"range":"3773","text":"3036"},{"range":"3774","text":"3036"},{"range